{
  "name": "trello-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Trello integration with Claude Code",
  "type": "module",
  "main": "build/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "dev": "tsc --watch",
    "start": "node build/index.js"
  },
  "keywords": ["mcp", "trello", "claude-code", "task-management"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "dotenv": "17.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "5.9.3"
  }
}
